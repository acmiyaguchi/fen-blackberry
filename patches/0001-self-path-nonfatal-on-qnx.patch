fen-blackberry port patch (NOT upstreamed; applied at build time only).

QNX/BlackBerry 10 has no /proc/self/exe. fen.c self_path() returns NULL
and main() treats that as a fatal early return 1 before the
absolute-argv[0] fallback. Make NULL non-fatal. Linux unchanged.

--- a/packages/fen/fen.c
+++ b/packages/fen/fen.c
@@ -622,14 +622,13 @@ static char *self_path(void) {
 
 int main(int argc, char **argv) {
   char *exe = self_path();
-  if (!exe) {
-    fprintf(stderr, "fen: cannot locate /proc/self/exe: %s\n", strerror(errno));
-    return 1;
-  }
-
+  /* fen-blackberry: QNX has no /proc/self/exe; a NULL self_path() must not
+   * be fatal -- fall through to the absolute-argv[0] fallback below. */
   int zip_err = 0;
-  embedded_zip = zip_openwitherror(exe, 0, 'r', &zip_err);
-  free(exe);
+  if (exe) {
+    embedded_zip = zip_openwitherror(exe, 0, 'r', &zip_err);
+    free(exe);
+  }
   if (!embedded_zip && argc > 0 && argv[0] && argv[0][0] == '/') {
     zip_err = 0;
     embedded_zip = zip_openwitherror(argv[0], 0, 'r', &zip_err);
